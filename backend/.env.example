# LLM provider — "groq" or "anthropic"
LLM_PROVIDER=groq

# Model name (must match the provider)
#   groq:      llama-3.3-70b-versatile
#   anthropic: claude-haiku-4-5
LLM_MODEL=llama-3.3-70b-versatile

# API keys
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Supabase (service role — server only; NOT the anon key)
# Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated frontend origins allowed to call this API directly (optional).
# Production invoke goes through Next.js /api/invoke; CORS is mainly for /health.
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Shared secret with the Next.js app (recommended in production)
INVOKE_SECRET=

# Frontend URL for Supabase Auth invite redirects
APP_URL=http://localhost:3000

# Embeddings (local fastembed, 384d — no API key)
EMBED_MODEL=BAAI/bge-small-en-v1.5
RAG_TOP_K=8
RAG_MAX_CONTEXT_TOKENS=4000
RAG_MIN_SIMILARITY=0.7

# Optional: GitHub API fallback when a workspace has no integration connected
GITHUB_TOKEN=

# GitHub OAuth App (Settings → Integrations → Connect with GitHub)
# Create at https://github.com/settings/developers — callback URL:
#   {APP_URL}/api/integrations/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Default: read:user repo
GITHUB_OAUTH_SCOPES=read:user repo

# Set by Render automatically
PORT=8000
