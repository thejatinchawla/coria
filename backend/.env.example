# LLM provider — "groq" or "anthropic"
LLM_PROVIDER=groq

# Model name (must match the provider)
#   groq:      llama-3.3-70b-versatile
#   anthropic: claude-haiku-4-5
LLM_MODEL=llama-3.3-70b-versatile

# API keys
ANTHROPIC_API_KEY=
GROQ_API_KEY=
TAVILY_API_KEY=

# Supabase (service role — server only)
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated frontend origins allowed to call this API directly (optional).
# Production invoke goes through Next.js /api/invoke; CORS is mainly for /health.
CORS_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# Shared secret with the Next.js app (recommended in production)
INVOKE_SECRET=

# Embeddings (local fastembed, 384d — no API key)
# Run: python -c "from fastembed import TextEmbedding; print([m['model'] for m in TextEmbedding.list_supported_models() if m.get('dim')==384])"
EMBED_MODEL=BAAI/bge-small-en-v1.5
RAG_TOP_K=8
RAG_MAX_CONTEXT_TOKENS=4000
RAG_MIN_SIMILARITY=0.7

# Optional: higher GitHub API rate limits for github_read tool
GITHUB_TOKEN=

# Set by Railway/Render automatically
PORT=8000
