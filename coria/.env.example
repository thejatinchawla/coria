# Supabase — Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# FastAPI agent service (local default shown)
BACKEND_URL=http://localhost:8000

# Must match backend/.env INVOKE_SECRET (generate: openssl rand -hex 32)
# Leave empty locally only if backend INVOKE_SECRET is also empty.
INVOKE_SECRET=
